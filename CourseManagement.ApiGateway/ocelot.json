{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/courses",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 8081
        },
        {
          "Host": "localhost",
          "Port": 8082
        },
        {
          "Host": "localhost",
          "Port": 8083
        }
      ],
      "UpstreamPathTemplate": "/courses",
      "UpstreamHttpMethod": [ "GET" ],
      "LoadBalancerOptions": {
        "Type": "RoundRobin",
        "Key": "course-api"
      }
    },
    {
      "DownstreamPathTemplate": "/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 8081
        },
        {
          "Host": "localhost",
          "Port": 8082
        },
        {
          "Host": "localhost",
          "Port": 8083
        }
      ],
      "UpstreamPathTemplate": "/health",
      "UpstreamHttpMethod": [ "GET" ],
      "Priority": 1,
      "LoadBalancerOptions": {
        "Type": "RoundRobin",
        "Key": "course-api-health"
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000"
  }
}