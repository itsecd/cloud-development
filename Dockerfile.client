FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY Client.Wasm/Client.Wasm.csproj Client.Wasm/
RUN dotnet restore Client.Wasm/Client.Wasm.csproj

COPY Client.Wasm/ Client.Wasm/
RUN dotnet publish Client.Wasm/Client.Wasm.csproj -c Release -o /app/publish

FROM node:20-alpine
RUN npm install -g http-server
COPY --from=build /app/publish/wwwroot /app
WORKDIR /app
EXPOSE 80
CMD ["http-server", ".", "-p", "80", "--cors"]