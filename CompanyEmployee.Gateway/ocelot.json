{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/employee",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 6001
        },
        {
          "Host": "localhost",
          "Port": 6002
        },
        {
          "Host": "localhost",
          "Port": 6003
        },
        {
          "Host": "localhost",
          "Port": 6004
        },
        {
          "Host": "localhost",
          "Port": 6005
        }
